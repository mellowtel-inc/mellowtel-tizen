<?xml version="1.0" encoding="UTF-8"?>
<widget xmlns="http://www.w3.org/ns/widgets"
        xmlns:tizen="http://tizen.org/ns/widgets"
        id="http://mellowtel.com/tizen-demo"
        version="0.1.0"
        viewmodes="maximized">

  <tizen:application id="MellowtelD.demo"
                     package="MellowtelD"
                     required_version="6.0"/>

  <name>Mellowtel Demo</name>
  <author>mellowtel-inc</author>
  <description>Demo Tizen TV app integrating the mellowtel-tizen SDK.</description>

  <icon src="icon.png"/>
  <content src="index.html"/>

  <!-- REQUIRED: cross-origin fetch + WebSocket for the SDK -->
  <tizen:privilege name="http://tizen.org/privilege/internet"/>

  <!-- TV profile -->
  <tizen:profile name="tv"/>

  <!-- Allow the SDK to reach its backends over https/wss -->
  <access origin="*" subdomains="true"/>
  <access origin="https://api.mellow.tel" subdomains="true"></access>

  <feature name="http://tizen.org/feature/screen.size.normal.1080.1920"/>
</widget>
